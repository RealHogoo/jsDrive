APP_ENV=dev
SERVICE_ID=webhard-service
PORT=8083
PUBLIC_BASE_URL=http://localhost:8083
ADMIN_SERVICE_BASE_URL=http://localhost:8081
ADMIN_INTERNAL_API_TOKEN=dev-media-internal-token
MEDIA_INTERNAL_API_TOKEN=dev-media-internal-token
MEDIA_INTERNAL_ALLOWED_IPS=127.0.0.1,::1
WEBHARD_DB_HOST=localhost
WEBHARD_DB_PORT=5432
WEBHARD_DB_DATABASE=webhard
WEBHARD_DB_USERNAME=postgres
WEBHARD_DB_PASSWORD=postgres
WEBHARD_STORAGE_ROOT=./storage
WEBHARD_UPLOAD_MAX_FILE_MB=100
WEBHARD_UPLOAD_MAX_TOTAL_MB=500
WEBHARD_WEEK_DOWNLOAD_MAX_FILES=500
WEBHARD_WEEK_DOWNLOAD_MAX_MB=2048
WEBHARD_DOWNLOAD_JOB_RETENTION_DAYS=7
WEBHARD_DOWNLOAD_CLEANUP_INTERVAL_HOURS=24
WEBHARD_TRASH_RETENTION_DAYS=30
FFMPEG_PATH=ffmpeg
TRUST_FORWARDED_HEADERS=false
